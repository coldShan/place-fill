{
  "manifest_version": 3,
  "name": "place-fill",
  "version": "0.3.5",
  "description": "Generate legal-looking test data for fast form testing.",
  "permissions": ["clipboardWrite", "contextMenus", "storage"],
  "host_permissions": ["https://api.github.com/repos/coldShan/place-fill/*"],
  "icons": {
    "16": "assets/app-icons/icon-16.png",
    "32": "assets/app-icons/icon-32.png",
    "48": "assets/app-icons/icon-48.png",
    "128": "assets/app-icons/icon-128.png"
  },
  "action": {
    "default_title": "place-fill",
    "default_icon": {
      "16": "assets/app-icons/icon-16.png",
      "32": "assets/app-icons/icon-32.png",
      "48": "assets/app-icons/icon-48.png",
      "128": "assets/app-icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/icons/lucide/*.svg"],
      "matches": ["<all_urls>"]
    },
    {
      "resources": ["assets/app-icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "all_frames": true,
      "js": ["src/field-meta.js", "src/field-visibility.js", "src/generators.js", "src/panel-state.js", "src/editable-target.js", "src/icon-assets.js", "src/smart-fill.js", "src/content-script-panel.js", "src/content-script-smartfill.js", "src/content-script.js"],
      "css": ["src/sidepanel.css"],
      "run_at": "document_idle"
    }
  ]
}
